      "parameters": {
        "language": "javaScript",
        "jsCode": "// Read + sanitize the token from the query string. Empty token short-circuits to a not-found response.\nconst item = $input.first();\nconst raw = (item.json && item.json.query && item.json.query.token) || (item.json && item.json.token) || '';\nconst token = String(raw).trim().replace(/[^a-z0-9]/gi, '').toLowerCase().substring(0, 64);\nreturn [{ json: { token, has_token: token.length > 0 } }];"
      },
      "id": "code-read-token",
