    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Defensive shaping: handle missing fields, missing tutors, missing slots without crashing.\nconst pickFields = (rec) => (rec && rec.fields) ? rec.fields : (rec || {});\nconst pickId = (rec) => (rec && (rec.id || rec.recordId)) || '';\n\nconst enrollmentRec = $('Airtable: Find Enrollment').first() && $('Airtable: Find Enrollment').first().json;\nconst e = pickFields(enrollmentRec);\n\nconst tutorRecs = $('Airtable: List Tutors').all().map(i => i.json).filter(t => t && (t.id || t.fields));\nconst slotRecs = $('Airtable: List Slots').all().map(i => i.json).filter(s => s && (s.id || s.fields));\n\nconst available_tutors = tutorRecs.map(t => {\n  const tf = pickFields(t);\n  const tutorId = pickId(t);\n  const tutorSlots = slotRecs\n    .filter(s => {\n      const linked = (pickFields(s).tutor) || [];\n      return Array.isArray(linked) ? linked.includes(tutorId) : linked === tutorId;\n    })\n    .map(s => ({\n      id: pickId(s),\n      datetime: pickFields(s).slot_datetime || ''\n    }))\n    .filter(s => s.id && s.datetime);\n  return {\n    id: tutorId,\n    name: tf.name || 'Tutor',\n    subjects: Array.isArray(tf.subjects) ? tf.subjects : (tf.subjects ? [tf.subjects] : []),\n    available_slots: tutorSlots\n  };\n}).filter(t => t.id && t.available_slots.length > 0);\n\nreturn [{\n  json: {\n    student_name: e.student_name || '',\n    parent_name: e.parent_name || '',\n    course: e.course || '',\n    classes_count: Number(e.classes_count) || 0,\n    amount: Number(e.amount) || 0,\n    currency: e.currency || 'INR',\n    demo_tutor: e.demo_tutor || '',\n    available_tutors\n  }\n}];"
      },
