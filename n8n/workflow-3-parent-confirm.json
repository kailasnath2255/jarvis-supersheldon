    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Centralize all derived data: end time, attendees, formatted slot.\nconst slot = $('Airtable: Get Slot').first().json || {};\nconst slotFields = slot.fields || slot || {};\nconst tutor = $('Airtable: Get Tutor').first().json || {};\nconst tutorFields = tutor.fields || tutor || {};\nconst enrollment = $('Airtable: Find Enrollment').first().json || {};\nconst enrollmentFields = enrollment.fields || enrollment || {};\n\nif (!enrollment.id) throw new Error('Enrollment not found for token');\nif (!slotFields.slot_datetime) throw new Error('Selected slot has no datetime');\n\nconst startMs = new Date(slotFields.slot_datetime).getTime();\nif (!Number.isFinite(startMs)) throw new Error('Selected slot datetime is invalid');\n\nconst startIso = new Date(startMs).toISOString();\nconst endIso = new Date(startMs + 60 * 60 * 1000).toISOString();\n\nconst attendees = [enrollmentFields.parent_email, tutorFields.email]\n  .filter(Boolean).map(e => String(e).trim()).filter(Boolean);\n\nconst pad = (n) => String(n).padStart(2, '0');\nconst formatNice = (iso) => {\n  const d = new Date(iso);\n  if (!Number.isFinite(d.getTime())) return iso;\n  const date = d.toLocaleDateString('en-IN', { weekday: 'long', day: 'numeric', month: 'long' });\n  const h24 = d.getHours();\n  const h12 = ((h24 + 11) % 12) + 1;\n  const ampm = h24 >= 12 ? 'PM' : 'AM';\n  return `${date} · ${h12}:${pad(d.getMinutes())} ${ampm}`;\n};\n\nreturn [{\n  json: {\n    enrollment_id: enrollment.id,\n    tutor_id: tutor.id || $('Parse body').first().json.selected_tutor_id,\n    slot_id: slot.id || $('Parse body').first().json.selected_slot_id,\n    student_name: enrollmentFields.student_name || '',\n    parent_name: enrollmentFields.parent_name || '',\n    parent_email: enrollmentFields.parent_email || '',\n    parent_whatsapp: enrollmentFields.parent_whatsapp || '',\n    course: enrollmentFields.course || '',\n    tutor_name: tutorFields.name || 'Tutor',\n    tutor_email: tutorFields.email || '',\n    slot_start: startIso,\n    slot_end: endIso,\n    slot_pretty: formatNice(startIso),\n    attendees\n  }\n}];"
      },
