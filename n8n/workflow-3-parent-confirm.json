    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Build minimal update payload for Enrollments. Map Automatically uses these field names.\nconst prep = $('Prepare data').first().json;\nconst calOut = $input.first().json || {};\nconst meetLink = calOut.hangoutLink\n  || (calOut.conferenceData && calOut.conferenceData.entryPoints && calOut.conferenceData.entryPoints[0] && calOut.conferenceData.entryPoints[0].uri)\n  || '';\nreturn [{\n  json: {\n    id: prep.enrollment_id,\n    selected_tutor: [prep.tutor_id],\n    selected_slot_datetime: prep.slot_start,\n    meet_link: meetLink,\n    parent_confirmed: true,\n    meet_created: true,\n    status: 'Booked',\n    _meet_link_for_downstream: meetLink\n  }\n}];"
      },
