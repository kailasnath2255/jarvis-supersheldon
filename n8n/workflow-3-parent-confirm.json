    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const item = $input.first();\nconst rawBody = (item.json && item.json.body) ? item.json.body : item.json;\nconst body = rawBody || {};\nconst safe = (v, fb = '') => (v === undefined || v === null) ? fb : String(v).trim();\nconst token = safe(body.magic_token).replace(/[^a-z0-9]/gi, '').toLowerCase().substring(0, 64);\nconst tutorId = safe(body.selected_tutor_id);\nconst slotId = safe(body.selected_slot_id);\nif (!token || !tutorId || !slotId) {\n  throw new Error('Missing required fields: magic_token, selected_tutor_id, or selected_slot_id');\n}\nreturn [{ json: { magic_token: token, selected_tutor_id: tutorId, selected_slot_id: slotId } }];"
      },
      "id": "code-parse-body",
      "name": "Parse body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 300]
    },
    {
      "parameters": {
