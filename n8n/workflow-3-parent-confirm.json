        "emailType": "html",
        "message": "=<div style=\"font-family:Inter,system-ui,sans-serif;max-width:560px;margin:0 auto;color:#2A2E36;\"><div style=\"background:#FF6B1F;padding:24px;border-radius:16px 16px 0 0;color:white\"><h1 style=\"margin:0;font-family:'Plus Jakarta Sans',sans-serif;font-size:24px\">You're all set! 🎉</h1></div><div style=\"background:white;border:1px solid #E5E8EE;border-top:none;padding:24px;border-radius:0 0 16px 16px\"><p>Hi {{ $('Prepare data').item.json.parent_name }},</p><p><b>{{ $('Prepare data').item.json.student_name }}</b>'s <b>{{ $('Prepare data').item.json.course }}</b> class is confirmed.</p><table style=\"width:100%;border-collapse:collapse;margin:16px 0\"><tr><td style=\"padding:8px 0;color:#5B6271\">When</td><td style=\"padding:8px 0;font-weight:600\">{{ $('Prepare data').item.json.slot_pretty }}</td></tr><tr><td style=\"padding:8px 0;color:#5B6271\">Tutor</td><td style=\"padding:8px 0;font-weight:600\">{{ $('Prepare data').item.json.tutor_name }}</td></tr></table><p style=\"text-align:center;margin:24px 0\"><a href=\"{{ $('Prep enrollment update').item.json._meet_link_for_downstream }}\" style=\"background:#FF6B1F;color:white;padding:12px 24px;border-radius:9999px;text-decoration:none;font-weight:600;display:inline-block\">Open Google Meet →</a></p><p style=\"color:#5B6271;font-size:14px\">A calendar invite has also been emailed to you.</p><p style=\"color:#5B6271;font-size:14px;margin-top:24px\">— Team Super Sheldon</p></div></div>",
